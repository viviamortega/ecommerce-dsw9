<div class="d-flex justify-content-between align-items-center mb-4">
  <h2 class="section-title mb-0">Todos los <span>Productos</span></h2>
  <span class="text-muted small"><%= products.length %> producto(s)</span>
</div>

<% if (products.length === 0) { %>
  <div class="alert alert-info">No hay productos disponibles.</div>
<% } else { %>
  <div class="row row-cols-1 row-cols-md-3 row-cols-lg-4 g-4">
    <% for (let product of products) { %>
      <div class="col">
        <div class="card product-card">
          <img src="<%= product.imageUrl %>" alt="<%= product.name %>"
               onerror="this.src='/images/placeholder.jpg'">
          <div class="card-body d-flex flex-column">
            <h5 class="card-title"><%= product.name %></h5>
            <p class="text-muted small text-truncate"><%= product.description %></p>
            <div class="d-flex justify-content-between align-items-center mt-auto pt-2">
              <span class="price-tag">$<%= parseFloat(product.price).toFixed(2) %></span>
              <span class="badge-stock <%= product.stock === 0 ? 'out' : '' %>">
                <% if (product.stock === 0) { %>Agotado<% } else { %>
                  <i class="bi bi-check2"></i> En stock
                <% } %>
              </span>
            </div>
            <a href="/products/<%= product.id %>"
               class="btn btn-primary btn-sm w-100 mt-3">Ver producto</a>
          </div>
        </div>
      </div>
    <% } %>
  </div>
<% } %>