<div class="d-flex justify-content-between align-items-center mb-4">
  <h2 class="section-title mb-0">Tu <span>Carrito</span></h2>
  <a href="/products" class="btn btn-outline-primary btn-sm">
    <i class="bi bi-arrow-left me-1"></i> Seguir comprando
  </a>
</div>

<% if (!cart || cart.items.length === 0) { %>
  <div class="text-center py-5">
    <i class="bi bi-cart-x" style="font-size:4rem;color:var(--border)"></i>
    <h4 class="mt-3 text-muted">Tu carrito está vacío</h4>
    <a href="/products" class="btn btn-primary mt-3">Explorar productos</a>
  </div>
<% } else { %>
<div class="table-responsive cart-table">
  <table class="table mb-0">
    <thead>
      <tr>
        <th>Producto</th>
        <th class="text-center">Precio</th>
        <th class="text-center">Cantidad</th>
        <th class="text-center">Subtotal</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% for (let item of cart.items) { %>
        <tr>
          <td>
            <div class="d-flex align-items-center gap-3">
              <img src="<%= item.product.imageUrl %>"
                   style="width:56px;height:56px;object-fit:cover;border-radius:8px"
                   onerror="this.src='/images/placeholder.jpg'">
              <div>
                <div class="fw-semibold"><%= item.product.name %></div>
                <div class="text-muted small">Unidad: $<%= parseFloat(item.product.price).toFixed(2) %></div>
              </div>
            </div>
          </td>
          <td class="text-center align-middle">$<%= parseFloat(item.product.price).toFixed(2) %></td>
          <td class="text-center align-middle">
            <form action="/cart/update" method="POST" class="d-inline">
              <input type="hidden" name="productId" value="<%= item.product.id %>">
              <input type="number" name="quantity" value="<%= item.quantity %>"
                     min="1" class="qty-input"
                     onchange="this.form.submit()">
            </form>
          </td>
          <td class="text-center align-middle fw-semibold">
            $<%= (item.product.price * item.quantity).toFixed(2) %>
          </td>
          <td class="text-center align-middle">
            <form action="/cart/remove" method="POST">
              <input type="hidden" name="productId" value="<%= item.product.id %>">
              <button type="submit" class="btn btn-sm btn-danger">
                <i class="bi bi-trash"></i>
              </button>
            </form>
          </td>
        </tr>
      <% } %>
    </tbody>
    <tfoot>
      <tr class="cart-total-row">
        <td colspan="3" class="text-end pe-4 py-3">Total:</td>
        <td class="text-center py-3" style="font-size:1.2rem;color:var(--accent)">
          $<%= parseFloat(cart.totalPrice).toFixed(2) %>
        </td>
        <td></td>
      </tr>
    </tfoot>
  </table>
</div>

<div class="d-flex justify-content-end mt-4">
  <a href="/checkout" class="btn btn-primary btn-lg">
    Proceder al pago <i class="bi bi-arrow-right ms-2"></i>
  </a>
</div>
<% } %>