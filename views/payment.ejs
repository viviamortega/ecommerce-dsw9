<div class="row mt-4">
  <div class="col-md-6 mx-auto">
    <div class="card shadow-sm">
      <div class="card-header bg-primary text-white">
        <h5 class="mb-0">Pagar con PayPal — Orden #<%= order.id %></h5>
      </div>
      <div class="card-body text-center">
        <p class="mb-1"><strong>Total a pagar:</strong>
          <span class="text-primary h4"> $<%= parseFloat(order.total).toFixed(2) %></span>
        </p>
        <p class="text-muted small mb-4">Modo Sandbox — sin cargos reales</p>
        <!-- PayPal inyecta los botones aquí -->
        <div id="paypal-button-container"></div>
        <div id="pay-message" class="mt-3"></div>
      </div>
    </div>
    <a href="/checkout/cancel?orderId=<%= order.id %>"
       class="btn btn-outline-secondary btn-block mt-3">Cancelar pedido</a>
  </div>
</div>

<!-- SDK de PayPal: el client-id viene del servidor -->
<script src="https://www.paypal.com/sdk/js?client-id=<%= paypalClientId %>&currency=USD"></script>
<script>
  const ORDER_ID = '<%= order.id %>';
  paypal.Buttons({
    // Paso 1: crear la orden en PayPal a través de nuestro servidor
    createOrder: async () => {
      const res  = await fetch('/checkout/create-paypal-order', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ orderId: ORDER_ID })
      });
      const data = await res.json();
      return data.id; // ID de la orden PayPal
    },
    // Paso 2: capturar el pago después de que el usuario aprueba
    onApprove: async (data) => {
      document.getElementById('pay-message').innerHTML =
        '<div class="alert alert-info">Procesando tu pago...</div>';
      const res    = await fetch('/checkout/capture-paypal-order', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ paypalOrderId: data.orderID, orderId: ORDER_ID })
      });
      const result = await res.json();
      if (result.success) {
        window.location.href = '/checkout/success?orderId=' + result.orderId;
      } else {
        document.getElementById('pay-message').innerHTML =
          '<div class="alert alert-danger">El pago no fue completado. Intenta nuevamente.</div>';
      }
    },
    onError: (err) => {
      document.getElementById('pay-message').innerHTML =
        '<div class="alert alert-danger">Error en el pago: ' + err + '</div>';
    },
    onCancel: () => {
      window.location.href = '/checkout/cancel?orderId=' + ORDER_ID;
    }
  }).render('#paypal-button-container');
</script>