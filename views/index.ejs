<!-- Hero section -->
<div class="hero">
  <div class="container">
    <div class="row align-items-center">
      <div class="col-lg-6">
        <h1>Encuentra lo que <br>necesitas hoy</h1>
        <p>Los mejores productos al mejor precio, entregados directo a tu puerta.</p>
        <a class="btn btn-light btn-lg fw-bold" href="/products">
          <i class="bi bi-grid me-2"></i>Ver productos
        </a>
      </div>
    </div>
  </div>
</div>

<!-- Productos destacados -->
<h2 class="section-title">Productos <span>Destacados</span></h2>
<div class="row row-cols-1 row-cols-md-3 g-4 mb-5">
  <% if (featuredProducts.length === 0) { %>
    <div class="col-12">
      <div class="alert alert-info">No hay productos disponibles aún.</div>
    </div>
  <% } %>
  <% for (let product of featuredProducts) { %>
    <div class="col">
      <div class="card product-card">
        <img src="<%= product.imageUrl %>" alt="<%= product.name %>"
             onerror="this.src='/images/placeholder.jpg'">
        <div class="card-body d-flex flex-column">
          <h5 class="card-title"><%= product.name %></h5>
          <p class="text-muted small text-truncate mb-2"><%= product.description %></p>
          <div class="d-flex justify-content-between align-items-center mt-auto">
            <span class="price-tag">$<%= parseFloat(product.price).toFixed(2) %></span>
            <a href="/products/<%= product.id %>" class="btn btn-primary btn-sm">
              Ver más <i class="bi bi-arrow-right"></i>
            </a>
          </div>
        </div>
      </div>
    </div>
  <% } %>
</div>